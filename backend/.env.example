# Copier vers .env et remplir les valeurs (ne jamais committer .env).

# --- URL publique du frontend (QR, liens) : mobile data / Wi‑Fi externe ---
# Ex. https://abc123.ngrok-free.app  ou  https://app.votredomaine.ma
# Priorité : BASE_URL > PUBLIC_APP_URL > FRONTEND_BASE_URL > http://localhost:5173
# BASE_URL=https://votre-sous-domaine.ngrok-free.app
#
# Ancien nom encore supporté :
# FRONTEND_BASE_URL=http://localhost:5173

# --- OTP QR : par défaut le code s’affiche UNIQUEMENT sur la page (aucun SMS). ---
# Pour envoyer aussi un SMS via Twilio :
# QR_OTP_ENABLE_SMS=1
# Puis renseigner :
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=   (ou TWILIO_MESSAGING_SERVICE_SID=)
# QR_OTP_SMS_DOMAIN=172.20.10.2:5173   (WebOTP, si SMS activé)

# Secret serveur pour hacher les OTP (chaîne longue aléatoire en production).
QR_OTP_PEPPER=changez-moi-en-production-minimum-32-caracteres

# Journalisation SMS / OTP renforcée (y compris code en clair dans les logs).
# SMS_VERBOSE_LOG=1

# Déjà utilisées ailleurs
# DB_HOST=127.0.0.1
# FRONTEND_BASE_URL=http://localhost:5173
